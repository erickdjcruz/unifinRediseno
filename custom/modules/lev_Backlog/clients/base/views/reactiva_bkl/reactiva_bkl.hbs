<style>
    .modal {
        position: fixed; /* Stay in place */
        padding-top: 100px; /* Location of the box */
        padding-bottom: 100px;
        top: 0;
        left:0;
        background-color: rgb(0,0,0); /* Fallback color */
        background-color: rgba(0,0,0,0.4); /* Black w/ opacity */
    }

    /* Modal Content */
    .modal-content {
        position: relative;
        background-color: #fefefe;
        padding: 1;
        border: 1px solid #888;
        width: 100%;
        box-shadow: 0 4px 8px 0 rgba(0,0,0,0.2),0 6px 20px 0 rgba(0,0,0,0.19);
        -webkit-animation-name: animatetop;
        -webkit-animation-duration: 0.4s;
        animation-name: animatetop;
        animation-duration: 0.4s
    }

    .modal-header {
        padding: .5px 0px;
        background-color: #21618C;
        color: white;
        text-align: center;
    }

    .modal-body {
        padding: .5px 0px;
        font-size: 12px;
        text-align: center;
    }

    .modal-footer {
        padding: 2px 16px;
        margin-top: 30px;
        bottom: auto;
        background-color: #fefefe;
        color: #ffffff;
        font-size: 12px;
        text-align: center;
    }

    .modal-footer-link {
        padding: .5px 0px;
        margin-top: 30px;
        color: #21618C;
        text-align: center;
    }
</style>

<div id="reactiva_bkl" class="row-fluid">
	<div class="modal span12 " style="width:100%;height:100%">
		<div class="modal-content" style="margin:auto; width:50%">
			<div class="modal-header">
				<h3><b>Reactivación de Backlog</b></h3>
            </div>
            <div class="modal-body">
				<div class="row-fluid">
                    <div class="span2"></div>
                    <div class="span8 record-cell" data-type="text" style="margin-top:20px">
						<label for="motivo-reactivacion" class="record-label" style="font-weight:bold; display:block; margin-bottom:8px;">
							Motivo de reactivación <span style="color:red">*</span>
						</label>
						<textarea id="motivo-reactivacion" 
								  name="motivo-reactivacion" 
								  rows="4"
								  placeholder="Ejemplo: El cliente solicitó continuar con el proceso..." 
								  style="width:100%; padding:10px; border:1px solid #ccc; border-radius:8px; resize:vertical; font-size:14px;"></textarea>
                    </div>
                </div>
                <div style="display:flex; justify-content:space-between; margin-top:25px;">
					<button class="btn btn-light" id="btn-cancelar" style="flex:1; margin-right:10px; border-radius:8px;">Cancelar</button>
                    <button class="btn btn-primary" id="btn-solicitar-aprobacion" style="flex:1; border-radius:8px;">Solicitar aprobación</button>
                </div>
			</div>
		</div>
	</div>
</div>