<div class="panel panel-default" style="max-width: 600px; margin: 20px auto;">
    <div class="panel-heading">
        <h3 class="panel-title text-center">Solicitud de Asignación</h3>
    </div>
    <div class="panel-body" style="padding: 20px;">        
        {{#if acepta}}
            <p class="text-success"><strong>Asignación Procesada ✅</strong></p>
        {{/if}}

        {{#if rechaza}}
            <p class="text-danger"><strong>Asignación Rechazada ❌</strong></p>
        {{/if}}
    </div>
</div>
