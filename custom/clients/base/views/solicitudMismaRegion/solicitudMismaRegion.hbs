<style>
    .message {
        padding: 15px;
        border-radius: 5px;
        width: 100%;
        margin: 20px auto;
        font-size: 18px;
        font-weight: bold;
    }

    .success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .warning {
        background-color: #fff3cd;
        color: #856404;
        border: 1px solid #ffeeba;
    }
</style>

<div class="panel panel-default" style="max-width: 600px; margin: 20px auto;">
    <div class="panel-heading">
        <h3 class="panel-title text-center">Solicitud de Asignación</h3>
    </div>
    <div class="panel-body" style="padding: 20px;">
        {{#if puedeAprobar}}
            <form id="comentarioForm">
                <div class="form-group">
                    <label for="comentarios">Ingresa el motivo de aprobación/rechazo a  la solicitud de reasingnación  (150 - 500 caracteres):</label>
                    <textarea id="comentarios" name="comentarios" class="form-control" rows="8" columns="50"></textarea>
                </div>
                <button id="btnEnviar" type="submit" class="btn btn-primary">Enviar</button>
            </form>
        {{/if}}
        <div id="mensaje" class="message text-center" style="margin-top: 15px;">
            {{#if acepta}}
                <div class="message success">Se autorizó el cambio de asignación exitosamente!</div>
            {{/if}}

            {{#if rechaza}}
                <div class="message warning">Se rechazo el cambio de asignación.</div>
            {{/if}}
        </div>
    </div>
</div>
