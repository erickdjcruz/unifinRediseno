<style>
	.container {
		overflow-y: auto;
		display: block;
		width: 100%;
	}

	.cuentas {
		display: table;
		width: 90%;
	}

	.cuentasContainer {
		margin-top: 1%;
		overflow-y: auto;
		height: 300px;
	}

	#containerHeader {
		font-size: 18px;
		margin-top: 2%;
		margin-left: 1%;
		line-height: 10px;
	}

	#successful {
		margin-top: 10%;
		font-size: 25px;
		color: #33800d;
	}

	/* Modal background container */
	.modal-container {
		position: fixed;
		top: 0;
		left: 0;
		z-index: 9999;
		width: 100vw;
		height: 100vh;
		background-color: rgba(0, 0, 0, 0.5);
		/* oscurece fondo */
		display: flex;
		justify-content: center;
		align-items: center;
	}

	/* Modal principal */
	.custom-modal {
		background: #fff;
		width: 90%;
		max-width: 600px;
		max-height: 90vh;
		overflow-y: auto;
		border-radius: 10px;
		box-shadow: 0 0 15px rgba(0, 0, 0, 0.3);
	}

	.modal-header {
		padding: 15px;
		background-color: #f5f5f5;
		border-bottom: 1px solid #ddd;
	}

	.modal-body {
		padding: 20px;
	}

	.close {
		float: right;
		font-size: 28px;
		font-weight: bold;
		cursor: pointer;
	}

	.close:hover {
		color: red;
	}

	@media (max-width: 480px) {
		.custom-modal {
			width: 95%;
			max-height: 95vh;
		}

		.modal-header h2 {
			font-size: 18px;
		}

		.btn {
			width: 100%;
			margin-top: 10px;
		}
	}
</style>
